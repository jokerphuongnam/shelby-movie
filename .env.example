# ─── Aptos ────────────────────────────────────────────────
APTOS_NETWORK=testnet

# ─── Shelby Protocol ──────────────────────────────────────
SHELBY_API_KEY=your_shelby_api_key_here
SHELBY_RPC_URL=https://your-shelby-rpc-node

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://mongodb:27017/shelbymovie

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_CHUNK_TTL_SECONDS=3600

# ─── NATS ─────────────────────────────────────────────────
NATS_URL=nats://nats-server:4222

# ─── Services ─────────────────────────────────────────────
API_GATEWAY_PORT=3000
STREAM_NODE_PORT=4000
SESSION_TOKEN_TTL_HOURS=6

# ─── Frontend (public) ────────────────────────────────────
# Both point to nginx (port 80) — nginx routes /api/* and /stream/* internally
NEXT_PUBLIC_API_URL=http://localhost
NEXT_PUBLIC_STREAM_URL=http://localhost
NEXT_PUBLIC_APTOS_NETWORK=testnet
NEXT_PUBLIC_SHELBY_CONTRACT=0xYOUR_SHELBY_CONTRACT_ADDRESS
NEXT_PUBLIC_TREASURY_ADDRESS=0xYOUR_TREASURY_WALLET_ADDRESS
